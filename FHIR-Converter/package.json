{
	"name": "vscode-fhir-liquid-converter",
	"publisher": "servicewell",
	"displayName": "FHIR Liquid Converter",
	"description": "Enables the conversion of legacy formatted health data to FHIR, expanding the use cases for health data and enabling interoperability.",
	"version": "1.0.0",
	"license": "MIT",
	"preview": true,
	"homepage": "https://servicewell.visualstudio.com/swts/_git/vscode-fhir-liquid-converter",
	"repository": {
		"type": "git",
		"url": "https://servicewell.visualstudio.com/swts/_git/vscode-fhir-liquid-converter"
	},
	"icon": "assets/servicewell_logo_small.png",
	"galleryBanner": {
		"color": "#3c3c3c",
		"theme": "dark"
	},
	"enableProposedApi": true,
	"engines": {
		"vscode": "^1.44.0"
	},
	"categories": [
		"Azure",
		"Other"
	],
	"keywords": [
		"Azure",
		"Azure API for FHIR",
		"Azure FHIR Service",
		"Converter",
		"FHIR",
		"FHIR Server for Azure",
		"FHIR Service",
		"Healthcare",
		"HL7v2",
		"C-CDA",
		"Liquid"
	],
	"aiKey": "AIF-d9b70cd4-b9f9-4d70-929b-a071c400b217",
	"activationEvents": [
		"onCommand:vscode-fhir-liquid-converter.convert",
		"onCommand:vscode-fhir-liquid-converter.convertWithoutValidation",
		"onCommand:vscode-fhir-liquid-converter.updateTemplateFolder",
		"onCommand:vscode-fhir-liquid-converter.selectTemplate",
		"onCommand:vscode-fhir-liquid-converter.selectData",
		"onCommand:vscode-fhir-liquid-converter.createConverterWorkspace",
		"onCommand:vscode-fhir-liquid-converter.pullTemplates",
		"onCommand:vscode-fhir-liquid-converter.pullOfficialTemplates",
		"onCommand:vscode-fhir-liquid-converter.pullSampleData",
		"onCommand:vscode-fhir-liquid-converter.pushTemplates",
		"onCommand:vscode-fhir-liquid-converter.loginRegistry",
		"onCommand:vscode-fhir-liquid-converter.logoutRegistry",
		"workspaceContains:**/*.liquid"
	],
	"main": "./client/out/extension.js",
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": true
		},
		"virtualWorkspaces": false
	},
	"contributes": {
		"commands": [
			{
				"command": "vscode-fhir-liquid-converter.convert",
				"title": "FHIR Liquid Converter: Convert data"
			},
			{
				"command": "vscode-fhir-liquid-converter.convertWithoutValidation",
				"title": "FHIR Liquid Converter: Convert data without validation"
			},
			{
				"command": "vscode-fhir-liquid-converter.updateTemplateFolder",
				"title": "FHIR Liquid Converter: Update template folder"
			},
			{
				"command": "vscode-fhir-liquid-converter.selectTemplate",
				"title": "FHIR Liquid Converter: Select as template (*.liquid)"
			},
			{
				"command": "vscode-fhir-liquid-converter.selectData",
				"title": "FHIR Liquid Converter: Select as data (*.[hl7|ccda|json|xml])"
			},
			{
				"command": "vscode-fhir-liquid-converter.createConverterWorkspace",
				"title": "FHIR Liquid Converter: Create a converter workspace"
			},
			{
				"command": "vscode-fhir-liquid-converter.pullTemplates",
				"title": "FHIR Liquid Converter: Pull custom templates"
			},
			{
				"command": "vscode-fhir-liquid-converter.pullOfficialTemplates",
				"title": "FHIR Liquid Converter: Pull sample templates"
			},
			{
				"command": "vscode-fhir-liquid-converter.pullSampleData",
				"title": "FHIR Liquid Converter: Pull sample data"
			},
			{
				"command": "vscode-fhir-liquid-converter.pushTemplates",
				"title": "FHIR Liquid Converter: Push custom templates"
			},
			{
				"command": "vscode-fhir-liquid-converter.loginRegistry",
				"title": "FHIR Liquid Converter: Login to Azure Container Registry"
			},
			{
				"command": "vscode-fhir-liquid-converter.logoutRegistry",
				"title": "FHIR Liquid Converter: Logout from Azure Container Registry"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "vscode-fhir-liquid-converter.selectTemplate",
					"when": "false"
				},
				{
					"command": "vscode-fhir-liquid-converter.selectData",
					"when": "false"
				}
			],
			"explorer/context": [
				{
					"command": "vscode-fhir-liquid-converter.convert",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.convertWithoutValidation",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.selectTemplate",
					"group": "1_converter",
					"when": "resourceExtname == .liquid"
				},
				{
					"command": "vscode-fhir-liquid-converter.selectData",
					"group": "1_converter",
					"when": "resourceExtname == .hl7 || resourceExtname == .ccda || resourceExtname == .xml || resourceExtname == .json"
				}
			],
			"editor/context": [
				{
					"command": "vscode-fhir-liquid-converter.convert",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.convertWithoutValidation",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.updateTemplateFolder",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.createConverterWorkspace",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.pullTemplates",
					"group": "1_converter"
				},
				{
					"command": "vscode-fhir-liquid-converter.pushTemplates",
					"group": "1_converter"
				}
			]
		},
		"keybindings": [
			{
				"command": "vscode-fhir-liquid-converter.updateTemplateFolder",
				"key": "Ctrl+U"
			},
			{
				"command": "vscode-fhir-liquid-converter.createConverterWorkspace",
				"key": "Ctrl+W"
			},
			{
				"command": "vscode-fhir-liquid-converter.convert",
				"key": "Ctrl+R"
			},
			{
				"command": "vscode-fhir-liquid-converter.pullTemplates",
				"key": "Ctrl+L"
			},
			{
				"command": "vscode-fhir-liquid-converter.pushTemplates",
				"key": "Ctrl+H"
			},
			{
				"command": "vscode-fhir-liquid-converter.pullOfficialTemplates",
				"key": "Ctrl+T"
			},
			{
				"command": "vscode-fhir-liquid-converter.pullSampleData",
				"key": "Ctrl+D"
			},
			{
				"command": "vscode-fhir-liquid-converter.loginRegistry",
				"key": "Ctrl+I"
			},
			{
				"command": "vscode-fhir-liquid-converter.logoutRegistry",
				"key": "Ctrl+O"
			}
		],
		"configuration": {
			"type": "object",
			"title": "FHIR Liquid Converter",
			"properties": {
				"vscode-fhir-liquid-converter.enableDiffView": {
					"type": "boolean",
					"default": "true",
					"description": "Enable showing the differential view after converting data."
				},
				"vscode-fhir-liquid-converter.enableUnusedSegmentsDiagnostic": {
					"type": "boolean",
					"default": "true",
					"description": "Enable showing the unused segments diagnostic after converting data."
				},
				"vscode-fhir-liquid-converter.templateFolder": {
					"type": "string",
					"default": "",
					"description": "The path to the folder the templates are saved in."
				},
				"vscode-fhir-liquid-converter.resultFolder": {
					"type": "string",
					"default": "",
					"description": "The path to the folder the results are saved in."
				},
				"vscode-fhir-liquid-converter.engineFolderPath": {
					"type": "string",
					"default": "",
					"description": "The path to the folder the backend is compiled in."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",		
		"postinstall": "cd client && npm install && bash ./install-engine.sh && cd ../server && npm install && cd ..",
		"postinstall_with_git_bash": "cd client && npm install && \"C:\\Program Files\\Git\\bin\\bash.exe\" ./install-engine.sh && cd ../server && npm install && cd ..",
		"test": "npm run compile && node ./client/out/test/runTest.js && node ./server/out/test/runTest.js",
		"download-templates": "cd test-data && bash download-templates.sh",
		"download-templates_with_git_bash": "cd test-data && \"C:\\Program Files\\Git\\bin\\bash.exe\" download-templates.sh",
		"package": "vsce package --baseContentUrl \"https://dev.azure.com/servicewell/swts/_git/vscode-fhir-liquid-converter?path=\" --baseImagesUrl \"https://dev.azure.com/servicewell/swts/_git/vscode-fhir-liquid-converter?path=\"",
		"lint": "tslint --fix client/src/**/*.ts  server/src/**/*.ts"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/mocha": "^5.2.6",
		"@types/node": "^14.18.63",
		"@types/vscode": "^1.44.0",
		"chai": "^4.2.0",
		"chai-as-promised": "^7.1.1",
		"chai-subset": "^1.6.0",
		"glob": "^7.1.4",
		"mocha": "^10.1.0",
		"mocha-multi-reporters": "^1.5.1",
		"nyc": "^15.1.0",
		"reflect-metadata": "^0.1.13",
		"tslint": "^5.19.0",
		"typescript": "^3.8.3",
		"vsce": "^1.96.1",
		"vscode-test": "^1.2.0"
	}
}
